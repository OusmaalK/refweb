generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Article {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  subtitle  String
  content   String
  imagePath String
  author    String
  category  String
  lang      String
  createdAt DateTime @default(now())
}

model Subscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscribedAt DateTime @default(now())
  isActive     Boolean  @default(true)
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  lastLogin    DateTime @updatedAt
}